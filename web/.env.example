# Supabase — copy to web/.env.local and fill in from your project's
# Project Settings -> API Keys. Do NOT commit .env.local.

# Project URL (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Secret API key (sb_secret_...) — SERVER ONLY. Bypasses Row Level Security.
# Replaces the legacy service_role key. Create under Project Settings ->
# API Keys -> Secret keys. Never prefix with NEXT_PUBLIC_; never use in client code.
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# Publishable API key (sb_publishable_...) — safe to expose. Replaces the legacy
# anon key. Not used in Phase 1; needed for Phase 2 auth.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
